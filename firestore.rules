rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // Hilfsfunktionen
    // ============================================
    
    // Prüft, ob der Benutzer authentifiziert und kein anonymer Nutzer ist.
    // Dies stellt sicher, dass nur regulär angelegte Konten (Admins) Zugriff erhalten.
    function isAdmin() {
      return request.auth != null 
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // ============================================
    // Wunschpartner-Einträge
    // ============================================
    match /wuensche/{kindId} {

      // ✅ ERSTELLEN: Öffentlich erlaubt, ABER nur wenn der Eintrag noch nicht existiert.
      // Das verhindert serverseitig Doppeleinträge und filtert unerlaubte Felder.
      allow create: if
        // Dokument darf noch nicht existieren
        !exists(/databases/$(database)/documents/wuensche/$(kindId))
        // Struktur-Validierung: Nur definierte Felder sind beim Anlegen erlaubt
        && request.resource.data.keys().hasOnly([
          'vorname', 'nachname', 'email', 
          'wunsch1_vorname', 'wunsch1_nachname', 
          'wunsch2_vorname', 'wunsch2_nachname', 
          'wunsch3_vorname', 'wunsch3_nachname', 
          'timestamp', '_kindId'
        ])
        // Pflichtfelder müssen vorhanden und Strings sein
        && request.resource.data.vorname is string
        && request.resource.data.vorname.size() > 0
        && request.resource.data.nachname is string
        && request.resource.data.nachname.size() > 0
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        // Keine übermäßig langen Eingaben (Schutz vor Missbrauch)
        && request.resource.data.vorname.size() <= 50
        && request.resource.data.nachname.size() <= 50
        && request.resource.data.email.size() <= 100
        // Datenintegrität: _kindId muss exakt mit der Dokument-ID übereinstimmen
        && request.resource.data._kindId == kindId;

      // 🔒 LESEN, ÄNDERN, LÖSCHEN: Nur für eingeloggte Admins (keine anonymen Nutzer)
      allow read, update, delete: if isAdmin();
    }

    // ============================================
    // Einstellungen (Admin-Status-Synchronisation)
    // ============================================
    match /settings/{docId} {
      // 🔒 LESEN & SCHREIBEN: Nur für eingeloggte Admins
      allow read, write: if isAdmin();
    }

    // ============================================
    // Alle anderen Collections: kein Zugriff
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
